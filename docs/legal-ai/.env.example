# Environment
APP_ENV=local
APP_NAME=legal-engine-api
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# Security
INTERNAL_API_KEY=change-me
ADMIN_API_KEY=change-me
LEGAL_ENGINE_ADMIN_TOKEN=change-me
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Database
DATABASE_URL=postgresql+psycopg://legal:legal@localhost:5432/legal_mvp
REDIS_URL=redis://localhost:6379/0

# Object storage
OBJECT_STORAGE_PROVIDER=s3
S3_ENDPOINT_URL=
S3_REGION=eu-west-1
S3_BUCKET=legal-ai-documents
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me

# Vector store
VECTOR_STORE_PROVIDER=pinecone
PINECONE_API_KEY=change-me
PINECONE_INDEX_LEGAL_CURRENT=legal-current
PINECONE_INDEX_LEGAL_ARCHIVE=legal-archive
PINECONE_INDEX_LEGAL_CASES=legal-cases
PINECONE_INDEX_PROCUREMENT=procurement-data
QDRANT_URL=
QDRANT_API_KEY=

# Discovery and crawling
TAVILY_API_KEY=change-me
FIRECRAWL_API_KEY=change-me
CRAWL_MAX_PAGES_DEFAULT=10
CRAWL_TIMEOUT_SECONDS=60

# Parsing
PARSER_PROVIDER=docling
LLAMAPARSE_API_KEY=
UNSTRUCTURED_API_KEY=

# Embeddings
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=change-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_BATCH_SIZE=64

# Reranking
RERANK_PROVIDER=cohere
COHERE_API_KEY=change-me
COHERE_RERANK_MODEL=rerank-multilingual-v3.0
RERANK_TOP_N=12

# LLM generation
GENERATOR_PROVIDER=openai
GENERATOR_MODEL=gpt-4.1
GENERATOR_TEMPERATURE=0
GENERATOR_MAX_OUTPUT_TOKENS=2500

# LLM validation
VALIDATOR_PROVIDER=anthropic
ANTHROPIC_API_KEY=change-me
VALIDATOR_MODEL=claude-3-5-sonnet-latest
VALIDATOR_TEMPERATURE=0
VALIDATOR_MAX_OUTPUT_TOKENS=2500

# Observability
LANGFUSE_PUBLIC_KEY=change-me
LANGFUSE_SECRET_KEY=change-me
LANGFUSE_HOST=http://localhost:3000
HELICONE_API_KEY=

# Product policy
DEFAULT_ANSWER_MODE=strict
SOURCE_POLICY_PATH=docs/legal-ai/source-policy.yml
REQUIRE_OFFICIAL_SOURCE=true
REQUIRE_CURRENT_LAW=true
REQUIRE_VALIDATOR_PASS=true

# Limits
MAX_QUERY_LENGTH=4000
MAX_CONTEXT_CHUNKS=12
MAX_CHUNK_TOKENS=1200
REQUEST_TIMEOUT_SECONDS=120
