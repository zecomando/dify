# Legal Engine API local/staging configuration.
# Copy to an environment-specific secret store or local .env file; do not commit real secrets.

# SQLite default for local development. Leave LEGAL_ENGINE_DATABASE_URL empty to use SQLite.
LEGAL_ENGINE_DATABASE_PATH=.data/legal_engine.sqlite3

# PostgreSQL staging/production DSN. Store the real value as an environment secret.
LEGAL_ENGINE_DATABASE_URL=

# Required for protected /admin/* endpoints in any deployed environment.
LEGAL_ENGINE_ADMIN_TOKEN=

# Optional override for the source policy file.
LEGAL_SOURCE_POLICY_PATH=../docs/legal-ai/source-policy.yml

# Optional API base URL used by manual smoke scripts/workflows.
LEGAL_ENGINE_BASE_URL=http://127.0.0.1:8000
